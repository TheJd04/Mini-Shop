# Copy this file to .env and fill in your real values. Never commit .env.

# Your MongoDB Atlas connection string
# Example: mongodb+srv://yourUser:yourPassword@cluster0.xxxxx.mongodb.net/minishop?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/minishop?retryWrites=true&w=majority

# Any long random string. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

JWT_EXPIRES_IN=7d
PORT=5002
CLIENT_URL=http://localhost:5175
